# ⚠️ IMPORTANTE: Nunca commitear valores reales en este archivo
# Copiar a .env.local y agregar valores reales allí
# .env.local está en .gitignore y no se sube a Git

# ============================================
# NextAuth.js Configuration
# ============================================

# URL de la app (cambiar en producción)
NEXTAUTH_URL=http://localhost:3000

# Secreto para firmar tokens JWT
# Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=YOUR_NEXTAUTH_SECRET_HERE

# ============================================
# Google OAuth 2.0
# ============================================
# Crear en: https://console.cloud.google.com/apis/credentials
# Tipo: Web application
# Authorized redirect URIs:
#   - http://localhost:3000/api/auth/callback/google (dev)
#   - https://dulcitienda-app.vercel.app/api/auth/callback/google (prod)

GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_CLIENT_SECRET_HERE

# ============================================
# Convex Backend
# ============================================
# Esta URL es pública, puede estar en el código
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# CONVEX_DEPLOY_KEY: NUNCA aquí
# Va solo en .secure/credentials.md (local)
# NO se necesita en Vercel
